# Static marketing site for PyAdminer (pyadminer-web/).
# Build from repository root (pyadminer-web/ must exist on the host):
#   docker build -f docker/Dockerfile.pyadminer-web -t YOUR_USER/pyadminer-web:latest .

FROM nginx:1.27-alpine

COPY docker/nginx-pyadminer-web.conf /etc/nginx/conf.d/default.conf
COPY pyadminer-web/ /usr/share/nginx/html/

EXPOSE 80
